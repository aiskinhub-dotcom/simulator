# LLM API配置（支持 OpenAI SDK 格式的任意 LLM）
# 推荐使用阿里百炼平台Qwen-plus模型：https://bailian.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep 后端配置 =====
# 后端选择: 'cloud' 使用 Zep Cloud | 'graphiti' 使用本地 Neo4j
ZEP_BACKEND=cloud

# Zep Cloud 配置（ZEP_BACKEND=cloud 时必需）
# 每月免费额度即可支撑使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Graphiti / Neo4j 本地配置（ZEP_BACKEND=graphiti 时必需）=====
# 启动 Neo4j: docker-compose -f docker-compose.local.yml up -d
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Graphiti 需要 OpenAI 兼容的 LLM 用于实体抽取
# OPENAI_API_KEY/OPENAI_BASE_URL 会自动从 LLM_API_KEY/LLM_BASE_URL 映射
# 如需单独配置 Graphiti 使用的 LLM，可显式设置：
# OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Graphiti 默认模型（推荐显式配置，避免使用 OpenAI 默认模型名导致不兼容）
# - DashScope chat: qwen3-max
# - DashScope embedding: text-embedding-v4
GRAPHITI_LLM_MODEL=qwen3-max
GRAPHITI_EMBEDDING_MODEL=text-embedding-v4

# 搜索重排序配置（可选）
# 非标准 OpenAI API（如 DashScope）会自动降级为 RRF 重排序
# 如确认你的 API 支持 logprobs，可强制使用 cross_encoder：
# GRAPHITI_FORCE_CROSS_ENCODER=true

# ===== 加速 LLM 配置（可选）=====
LLM_BOOST_API_KEY=your_boost_api_key_here
LLM_BOOST_BASE_URL=https://another-api-provider.com/v1
LLM_BOOST_MODEL_NAME=gpt-4o-mini
